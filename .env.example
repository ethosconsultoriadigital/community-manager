DATABASE_URL=postgresql://postgres:devpass@localhost:5433/community_manager
REDIS_URL=redis://localhost:6379
JWT_SECRET=
JWT_EXPIRES_IN=7d
# 32 bytes en base64 — generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=
META_APP_ID=
META_APP_SECRET=
# Debe coincidir exactamente con la URL configurada en la app de Meta
META_REDIRECT_URI=http://localhost:4000/oauth/meta/callback
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_REGION=auto
# URL pública para media local (Meta debe poder descargar el archivo)
MEDIA_PUBLIC_BASE_URL=http://localhost:4000
LLM_API_KEY=
IMAGE_API_KEY=
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
# Debe coincidir con la URL configurada en la integración de Canva Connect
CANVA_REDIRECT_URI=http://localhost:4000/oauth/canva/callback
CANVA_RETURN_URL=http://localhost:4000/oauth/canva/return
# Opcional: plantilla por defecto si el cliente no define brand.canva.brandTemplateId
CANVA_DEFAULT_BRAND_TEMPLATE_ID=
# Opcional: token de desarrollo sin OAuth (solo pruebas locales)
CANVA_ACCESS_TOKEN=
# Horas antes de volver a sincronizar métricas de un post (Fase I)
METRICS_STALE_HOURS=6
